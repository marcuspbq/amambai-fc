# ─────────────────────────────────────────────────
# Amambaí F.C. — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ─────────────────────────────────────────────────

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# API-Football (https://api-sports.io)
# Plano gratuito: 100 req/dia — suficiente para testes
# Plano pago ($12/mês): recomendado durante a Copa
FOOTBALL_API_KEY=sua_api_key_aqui
FOOTBALL_API_HOST=v3.football.api-sports.io

# ID da Copa do Mundo na API-Football
# Copa 2026: buscar em /leagues após configurar a chave
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# Segredo para rotas de API internas (gere um aleatório)
API_SECRET=gere_uma_string_aleatoria_longa_aqui
